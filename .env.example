# Test environment config. Copy to .env.local to override defaults.
# NOTE: .env.local is git-ignored — do not commit secrets.

# Base URL the tests drive (local dev server default)
BASE_URL=http://localhost:8080

# Mock JWT used by tests (any JWT-shaped string works since client-side decode only)
TEST_JWT=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJ0ZXN0IiwiZXhwIjo5OTk5OTk5OTk5fQ.test

# CI mode (set automatically in CI; overrides retries + workers)
CI=false
